# TrailBase API URL (required for creating test users)
# Default: https://origa.uwuwu.net
TRAILBASE_URL=https://origa.uwuwu.net

# Admin credentials for TrailBase API (required for user management)
# These are used to authenticate as admin to create/delete test users
ORIGA_ADMIN_EMAIL=admin@localhost
ORIGA_ADMIN_PASSWORD=your-admin-password-here

# Test user credentials (optional, will use defaults if not set)
TEST_USER_EMAIL=e2e-test@origa.local
TEST_USER_PASSWORD=e2e-test-password-123
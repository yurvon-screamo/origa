{
    admin off
}

:4000 {
    reverse_proxy localhost:8080

    encode gzip zstd

    @static_assets {
        path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.woff *.woff2 *.ttf *.eot *.ico *.webmanifest
    }
    header @static_assets Cache-Control "public, max-age=31536000, immutable"

    @dictionaries {
        path /public/dictionary/*.json
        path /public/domain/grammar/*.json
        path /public/dictionaries/unidic/*
    }
    header @dictionaries Cache-Control "public, max-age=86400, stale-while-revalidate=604800"

    @html {
        path *.html /
    }
    header @html Cache-Control "no-cache, no-store, must-revalidate"
}

{
    admin off
}

:4000 {
    encode gzip zstd

    @landing {
        path / /features /compare /download
        path /ru /ru/*
        path /robots.txt /sitemap.xml
        path /landing.processed.css /favicon.png
        path /images/*
    }
    handle @landing {
        reverse_proxy localhost:3000
    }

    @api path /api/*
    handle @api {
        reverse_proxy localhost:8080
    }

    handle {
        @static_files {
            path *.js *.css *.json *.png *.jpg *.jpeg *.gif *.svg *.woff *.woff2 *.ttf *.eot *.ico *.webmanifest *.wasm
        }
        header @static_files Cache-Control "public, max-age=2592000, immutable"

        @html {
            path *.html /
        }
        header @html Cache-Control "no-cache, no-store, must-revalidate"
        header @html Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' {env.ORIGA_CDN_BASE_URL} https://origa.uwuwu.net https://huggingface.co; img-src 'self' data: blob: {env.ORIGA_CDN_BASE_URL} https://origa.app; media-src 'self' blob: {env.ORIGA_CDN_BASE_URL}; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; form-action 'self' https://accounts.google.com https://oauth.yandex.ru; frame-ancestors 'none'"

        try_files {path} /index.html
        file_server
    }
}
